#!/bin/bash
# Sync .claude/skills/ to ~/GitHub repo after commit.
# Triggers only when .claude/skills/ was changed.
# Install: cp scripts/post-commit .git/hooks/post-commit && chmod +x .git/hooks/post-commit

# Check if this commit touched .claude/skills/
if ! git diff-tree --no-commit-id -r HEAD --name-only | grep -q '^\.claude/skills/'; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
TARGET="$HOME/GitHub/.claude/skills"

if [ ! -d "$TARGET" ]; then
  echo "[post-commit] Warning: $TARGET not found, skipping skills sync"
  exit 0
fi

cp -r "$REPO_ROOT/.claude/skills/." "$TARGET/"

cd "$HOME/GitHub" && git add .claude/skills/ && \
  git diff --cached --quiet && echo "[post-commit] Skills already up to date" || \
  git commit -m "Sync skills from personal-AI-agent" && \
  echo "[post-commit] Skills synced and committed to ~/GitHub"
