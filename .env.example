# Jarvis environment variables (Claude Agent SDK)
# Copy this file to .env and fill values.

# Required for Claude API access
ANTHROPIC_API_KEY=

# Optional Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_USER_ID=

# Model aliases (haiku/sonnet/opus or full model IDs)
JARVIS_MODEL_DEFAULT=haiku
JARVIS_MODEL_PLANNING=sonnet
JARVIS_MODEL_CRITICAL=opus

# Budget safety limits
JARVIS_MAX_BUDGET_PER_QUERY=0.30
JARVIS_MAX_BUDGET_PER_DAY=2.00

# Optional MCP GitHub token
GITHUB_TOKEN=

# Optional Claude Code CLI override for delegation coding agent
CLAUDE_CLI_PATH=claude
