# Example .env file for Jarvis AI Agent
# Copy this to .env and fill in your values

# LLM Configuration - Choose ONE provider:

# Option 1: Groq (FREE, fast, recommended for MVP)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (FREE, local, needs good PC)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Option 3: Google Gemini (FREE tier available)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash-exp

# Option 4: OpenAI (PAID)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# Jarvis Configuration
JARVIS_LOG_LEVEL=INFO
JARVIS_DATA_DIR=./.jarvis
JARVIS_ENABLE_TELEMETRY=false

# Tool Configuration
TOOLS_REQUIRE_CONFIRMATION=true
TOOLS_ALLOW_SHELL=true
TOOLS_SHELL_WHITELIST=ls,pwd,echo,cat

# Memory Configuration
MEMORY_MAX_HISTORY=50
MEMORY_PERSIST=true
