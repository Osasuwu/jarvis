# Jarvis environment variables
# Copy this file to .env and fill in values.
# .env is loaded automatically by mcp-memory/server.py via python-dotenv.
# Do NOT commit .env — it's in .gitignore.

# ── Required: Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Required: Supabase memory (cross-device persistent memory) ────────────────
# Get from: Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── Optional: Voyage AI (semantic memory search) ─────────────────────────────
# Without this, memory_recall falls back to keyword search (still works).
# Get from: https://www.voyageai.com/
VOYAGE_API_KEY=

# ── Optional: Telegram integration ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_USER_ID=

# ── Optional: GitHub token (for MCP GitHub server) ───────────────────────────
GITHUB_TOKEN=

# ── Optional: Firecrawl (web research in /research and /nightly-research) ────
FIRECRAWL_API_KEY=

# ── Optional: Obsidian vault (for obsidian MCP server) ──────────────────────
OBSIDIAN_VAULT_PATH=

# ── Optional: Claude Code CLI override ───────────────────────────────────────
CLAUDE_CLI_PATH=claude

# ── Model routing (haiku/sonnet/opus or full model IDs) ──────────────────────
JARVIS_MODEL_DEFAULT=haiku
JARVIS_MODEL_PLANNING=sonnet
JARVIS_MODEL_CRITICAL=opus

# ── Budget safety limits ──────────────────────────────────────────────────────
JARVIS_MAX_BUDGET_PER_QUERY=0.30
JARVIS_MAX_BUDGET_PER_DAY=2.00
