{
  "mcpServers": {
    "memory": {
      "command": "python",
      "args": ["scripts/run-memory-server.py"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "obsidian": {
      "command": "npx",
      "args": ["-y", "@bitbonsai/mcpvault@latest", "${OBSIDIAN_VAULT_PATH}"]
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"]
    },
    "bambu-printer": {
      "command": "npx",
      "args": ["-y", "bambu-printer-mcp"],
      "env": {
        "BAMBU_IP": "${BAMBU_IP}",
        "BAMBU_TOKEN": "${BAMBU_TOKEN}",
        "BAMBU_SERIAL": "${BAMBU_SERIAL}"
      }
    },
    "uml": {
      "command": "python",
      "args": ["${UML_MCP_HOME}/server.py"],
      "cwd": "${UML_MCP_HOME}",
      "env": {
        "KROKI_SERVER": "http://localhost:8000",
        "USE_LOCAL_KROKI": "true"
      }
    }
  }
}
